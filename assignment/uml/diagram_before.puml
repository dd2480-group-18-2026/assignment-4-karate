@startuml diagram_before
skinparam 300 dpi
+class Suite {
	+ScenarioResult retryScenario(Scenario scenario)
	+Results updateResults(ScenarioResult sr)
}
+class Feature {
	-List<FeatureSection> sections
}
+class FeatureSection {
	-Scenario scenario
	-ScenarioOutline scenarioOutline

	+boolean isOutline()
	+Scenario getScenario()
	+void setScenario(Scenario scenario)
	+ScenarioOutline getScenarioOutline()
	+void setScenarioOutline(ScenarioOutline scenarioOutline)
}
+class FeatureParser {
	+enterScenarioOutline(KarateParser.ScenarioOutlineContext ctx)
}
+class ScenarioOutline {
	-List<ExamplesTable> examplesTables

	+List<Scenario> getScenarios(FeatureRuntime fr)
}
+class Scenario {
	-int exampleIndex
	-List<Tag> tags
	-Map<String, Object> exampleData;

	+boolean isEqualTo(Scenario other)
	+String getUniqueId() 
}
+class ExamplesTable {
	-ScenarioOutline outline
	-List<Tag> tags
}
+class ScenarioResult {
	-Scenario scenario

	+ScenarioResult fromKarateJson(File workingDir, Feature feature, Map<String, Object> map)
	+Map<String, Object> toKarateJson()
	-List<Map> getStepResults(boolean background)
	+int compareTo(ScenarioResult sr)
}

note top of FeatureSection : has either a Scenario or a ScenarioOutline

Feature o-- FeatureSection : "has multiple"
Feature <--> FeatureParser : "uses"
FeatureSection o.. Scenario : "may have a"
FeatureSection o.. ScenarioOutline : "may have a"
Suite --> ScenarioResult : "uses"
Suite --> Scenario : "uses"
FeatureParser --> ScenarioOutline : "creates"
FeatureParser --> ExamplesTable : "creates"
FeatureParser --> FeatureSection : "creates"
ScenarioOutline --> Scenario : "creates"
ScenarioOutline o-- ExamplesTable : "has multiple"
ScenarioResult o-- Scenario : "has a"
@enduml